    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <!-- Conexión en tiempo real con Google Firebase SDK -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, getDoc, collection, addDoc, onSnapshot } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // Configuración de base de datos
        let firebaseConfig;
        
        const configDeRespaldo = {
            apiKey: "AIzaSyA4_COMPLETA_CON_TUS_DATOS",
            authDomain: "tu-proyecto.firebaseapp.com",
            projectId: "tu-proyecto-id",
            storageBucket: "tu-proyecto.appspot.com",
            messagingSenderId: "1234567890",
            appId: "1:1234:web:1234"
        };

        try {
            firebaseConfig = typeof __firebase_config !== 'undefined' ? JSON.parse(__firebase_config) : configDeRespaldo;
        } catch (e) {
            firebaseConfig = configDeRespaldo;
        }

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'eco-ruta-sacsayhuaman-360';

        let currentUser = null;
        let map;
        const markersList = [];
        let treeIcon;
        let userTreeIcon;

        const sectoresCoordenadas = {
            llaullipata: [-13.5085, -71.9820],
            tambomachay: [-13.5110, -71.9805],
            chacan: [-13.5090, -71.9790]
        };

        let arbolesRegistrados = [];

        // Mensaje Toast Dinámico
        window.showToast = function(title, message, type = 'success') {
            const toast = document.getElementById('toast');
            const iconBox = document.getElementById('toast-icon-box');
            const icon = document.getElementById('toast-icon');
            const titleEl = document.getElementById('toast-title');
            const messageEl = document.getElementById('toast-message');

            titleEl.innerText = title;
            messageEl.innerText = message;

            if (type === 'error') {
                toast.classList.replace('border-eco-green', 'border-red-500');
                iconBox.className = "w-8 h-8 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0 text-red-500";
                icon.className = "fa-solid fa-circle-exclamation";
            } else if (type === 'warning') {
                toast.classList.replace('border-eco-green', 'border-yellow-500');
                iconBox.className = "w-8 h-8 rounded-full bg-yellow-100 flex items-center justify-center flex-shrink-0 text-yellow-500";
                icon.className = "fa-solid fa-triangle-exclamation";
            } else {
                toast.classList.replace('border-red-500', 'border-eco-green');
                toast.classList.replace('border-yellow-500', 'border-eco-green');
                iconBox.className = "w-8 h-8 rounded-full bg-eco-light flex items-center justify-center flex-shrink-0 text-eco-green";
                icon.className = "fa-solid fa-check";
            }

            toast.classList.remove('hidden');
            setTimeout(() => {
                toast.classList.remove('translate-x-full');
            }, 50);

            window.toastTimeout = setTimeout(() => {
                window.hideToast();
            }, 6000);
        }

        window.hideToast = function() {
            const toast = document.getElementById('toast');
            toast.classList.add('translate-x-full');
            setTimeout(() => {
                toast.classList.add('hidden');
            }, 300);
            if (window.toastTimeout) clearTimeout(window.toastTimeout);
        }

        // Inicio de sesión anónimo en Firebase
        const initAuth = async () => {
            try {
                if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                    await signInWithCustomToken(auth, __initial_auth_token);
                } else {
                    await signInAnonymously(auth);
                }
            } catch (error) {
                console.error("Error de autenticación:", error);
                showToast("Conexión limitada", "No se pudo sincronizar en la nube en tiempo real.", "warning");
            }
        };

        onAuthStateChanged(auth, (user) => {
            currentUser = user;
            if (user) {
                conectarBaseDatosTiempoReal();
            }
        });

        // Conectar y leer datos desde Firestore
        function conectarBaseDatosTiempoReal() {
            if (!currentUser) return;

            const collectionRef = collection(db, 'artifacts', appId, 'public', 'data', 'arboles');

            onSnapshot(collectionRef, (snapshot) => {
                arbolesRegistrados = [];
                snapshot.forEach((doc) => {
                    const data = doc.data();
                    arbolesRegistrados.push({
                        id: doc.id,
                        ...data
                    });
                });

                if (arbolesRegistrados.length === 0) {
                    crearDatosDemoIniciales();
                } else {
                    renderizarMarcadores();
                    actualizarContadoresUI();
                }
            }, (error) => {
                console.error("Error al leer Firestore:", error);
            });
        }

        // Datos iniciales de demostración
        async function crearDatosDemoIniciales() {
            const collectionRef = collection(db, 'artifacts', appId, 'public', 'data', 'arboles');
            const iniciales = [
                { lat: -13.5085, lng: -71.9820, name: "Queuña de la familia Pérez", type: "Queuña", date: "10 Oct 2025", user: "Familia Pérez", sector: "Llaullipata", co2: "15 kg", qr: "EcoRuta360_Perez" },
                { lat: -13.5110, lng: -71.9805, name: "Chachacomo - Promo 2025", type: "Chachacomo", date: "15 Nov 2025", user: "Promoción 2025", sector: "Tambomachay", co2: "8 kg", qr: "EcoRuta360_Promo2025" },
                { lat: -13.5090, lng: -71.9790, name: "Kantuta de María", type: "Kantuta", date: "20 Dic 2025", user: "María Alca", sector: "Chacán", co2: "3 kg", qr: "EcoRuta360_Maria" }
            ];

            for (const item of iniciales) {
                await addDoc(collectionRef, item);
            }
        }

        // Renderizado dinámico de marcadores en el mapa
        function renderizarMarcadores() {
            if (!map) return;

            markersList.forEach(m => map.removeLayer(m));
            markersList.length = 0;

            arbolesRegistrados.forEach((tree) => {
                const isCustom = isNaN(tree.id) && tree.id.length > 10;
                const icon = isCustom ? userTreeIcon : treeIcon;
                
                const marker = L.marker([tree.lat, tree.lng], { icon: icon }).addTo(map);
                markersList.push(marker);

                let popupContent = `
                    <div class="text-center p-2 font-sans text-gray-800">
                        <h4 class="font-bold text-eco-green text-sm mb-1">${tree.name}</h4>
                        <p class="text-xs text-gray-600 mb-2">Especie: ${tree.type} <br> Adoptante: ${tree.user}</p>
                        <button id="btn-popup-${tree.id}" class="bg-eco-earth text-white text-xs px-3 py-1.5 rounded-full hover:bg-yellow-700 w-full font-bold">Ver Perfil y QR</button>
                    </div>
                `;
                marker.bindPopup(popupContent);

                marker.on('popupopen', () => {
                    const btnPopup = document.getElementById(`btn-popup-${tree.id}`);
                    if (btnPopup) {
                        btnPopup.addEventListener('click', () => {
                            window.verPerfilArbol(tree.id);
                        });
                    }
                });
            });
        }

        // Actualizar contadores en la interfaz
        function actualizarContadoresUI() {
            const counterElement = document.getElementById('adoptions-counter');
            const hectaresElement = document.getElementById('hectares-counter');
            
            if (counterElement) {
                counterElement.innerText = arbolesRegistrados.length;
            }
            if (hectaresElement) {
                const hectares = (arbolesRegistrados.length * 0.01).toFixed(2);
                hectaresElement.innerText = hectares;
            }
        }

        // Cargar modal con el perfil del árbol
        window.verPerfilArbol = function(id) {
            const arbol = arbolesRegistrados.find(a => a.id === id);
            if (!arbol) return;

            if (map) map.closePopup();

            document.getElementById('modal-planta-nombre').innerText = `${arbol.name} (${arbol.type})`;
            document.getElementById('modal-adoptante').innerText = arbol.user;
            document.getElementById('modal-fecha').innerText = arbol.date;
            document.getElementById('modal-ubicacion').innerText = `${arbol.sector}, Cusco`;
            document.getElementById('modal-co2').innerText = arbol.co2 || "5 kg";
            document.getElementById('modal-cuidador').innerText = "Comunidad de Chacán y Univ. Continental";
            
            const modalImg = document.getElementById('modal-img');
            if (arbol.type.toLowerCase() === 'queuña') {
                modalImg.src = "https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?auto=format&fit=crop&w=600&q=80";
            } else if (arbol.type.toLowerCase() === 'chachacomo') {
                modalImg.src = "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=600&q=80";
            } else {
                modalImg.src = "https://images.unsplash.com/photo-1611095941910-67df90ba458a?auto=format&fit=crop&w=600&q=80";
            }

            const qrText = `EcoRuta_Cusco_ID_${arbol.id}_Adoptante_${arbol.user}_Planta_${arbol.type}`;
            const qrImgUrl = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(qrText)}`;
            document.getElementById('qr-img').src = qrImgUrl;

            openModal('tree-profile-modal');
        }

        // Acción de guardar un nuevo árbol (Panel de Control de Administrador)
        window.registrarPlantaSimulada = async function() {
            const nombre = document.getElementById('sim-nombre').value.trim();
            const planta = document.getElementById('sim-planta').value;
            const sectorClave = document.getElementById('sim-sector').value;

            if (!nombre) {
                showToast("Faltan datos", "Por favor ingresa el nombre de la persona que adoptó el árbol.", "warning");
                return;
            }

            if (!currentUser) {
                showToast("Acceso denegado", "Inicia sesión para subir registros a la nube.", "error");
                return;
            }

            const baseCoords = sectoresCoordenadas[sectorClave];
            const randomLat = baseCoords[0] + (Math.random() - 0.5) * 0.0015;
            const randomLng = baseCoords[1] + (Math.random() - 0.5) * 0.0015;

            const nuevoArbol = {
                lat: randomLat,
                lng: randomLng,
                name: `${planta} de ${nombre}`,
                type: planta,
                date: new Date().toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' }),
                user: nombre,
                sector: sectorClave.charAt(0).toUpperCase() + sectorClave.slice(1),
                co2: planta === 'Queuña' ? '1.5 kg' : (planta === 'Chachacomo' ? '1.2 kg' : '0.8 kg'),
                qr: `EcoRuta360_${nombre.replace(/\s+/g, '')}`
            };

            try {
                const collectionRef = collection(db, 'artifacts', appId, 'public', 'data', 'arboles');
                await addDoc(collectionRef, nuevoArbol);

                document.getElementById('sim-nombre').value = "";
                showToast("Registro Exitoso", `La planta de ${nombre} se ha publicado en el mapa en tiempo real.`, "success");
            } catch (error) {
                console.error("Error al registrar:", error);
                showToast("Error de Servidor", "No se pudo sincronizar en la nube.", "error");
            }
        }

        // Lógica de autenticación del administrador local
        window.loginAdmin = function(e) {
            e.preventDefault();
            const passwordField = document.getElementById('admin-password');
            const errorMsg = document.getElementById('login-error');
            
            if (passwordField.value === 'continental2026') {
                localStorage.setItem('ecoRutaAdmin', 'true');
                evaluarEstadoAdmin();
                closeModal('admin-login-modal');
                showToast("Sesión de Admin Iniciada", "¡Bienvenida Administradora! El Panel de Control ha sido activado junto al mapa.", "success");
                document.getElementById('mapa').scrollIntoView({ behavior: 'smooth' });
            } else {
                errorMsg.classList.remove('hidden');
            }
        }

        window.logoutAdmin = function() {
            localStorage.removeItem('ecoRutaAdmin');
            evaluarEstadoAdmin();
            showToast("Sesión Cerrada", "Has cerrado sesión como Administradora. El panel vuelve a ser invisible al público.", "info");
        }

        window.evaluarEstadoAdmin = function() {
            const isAdmin = localStorage.getItem('ecoRutaAdmin') === 'true';
            const adminPanel = document.getElementById('admin-sim-panel');
            const navAdminBadge = document.getElementById('nav-admin-badge');
            const navAdminBtn = document.getElementById('nav-admin-btn');

            if (isAdmin) {
                if (adminPanel) adminPanel.classList.remove('hidden');
                if (navAdminBadge) navAdminBadge.classList.remove('hidden');
                if (navAdminBtn) {
                    navAdminBtn.innerHTML = '<i class="fa-solid fa-unlock text-lg text-eco-earth"></i>';
                    navAdminBtn.title = "Sesión de Admin Activa";
                }
            } else {
                if (adminPanel) adminPanel.classList.add('hidden');
                if (navAdminBadge) navAdminBadge.classList.add('hidden');
                if (navAdminBtn) {
                    navAdminBtn.innerHTML = '<i class="fa-solid fa-lock text-lg"></i>';
                    navAdminBtn.title = "Acceso Administrador";
                }
            }
        }

        initAuth();

        window.addEventListener('DOMContentLoaded', () => {
            const lat = -13.5099;
            const lng = -71.9817;
            
            map = L.map('map', {
                scrollWheelZoom: false 
            }).setView([lat, lng], 15);

            L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
                attribution: 'Tiles &copy; Esri &mdash; Source: Esri, i-cubed, USDA, USGS, AEX, GeoEye, Getmapping, Aerogrid, IGN, IGP, UPR-EGP, and the GIS User Community',
                maxZoom: 18
            }).addTo(map);

            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager_only_labels/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; <a href="https://carto.com/attributions">CARTO</a>',
                subdomains: 'abcd',
                maxZoom: 18
            }).addTo(map);

            treeIcon = L.divIcon({
                className: 'custom-div-icon',
                html: "<div class='marker-pulse w-8 h-8 bg-eco-green rounded-full border-2 border-white shadow-lg flex items-center justify-center text-white'><i class='fa-solid fa-tree text-xs'></i></div>",
                iconSize: [30, 42],
                iconAnchor: [15, 42]
            });

            userTreeIcon = L.divIcon({
                className: 'custom-div-icon',
                html: "<div class='marker-pulse w-10 h-10 bg-eco-earth rounded-full border-2 border-white shadow-lg flex items-center justify-center text-white'><i class='fa-solid fa-seedling text-sm'></i></div>",
                iconSize: [40, 40],
                iconAnchor: [20, 40]
            });

            const reforestZone = [
                [-13.507, -71.985],
                [-13.506, -71.980],
                [-13.509, -71.977],
                [-13.513, -71.981],
                [-13.512, -71.986]
            ];
            
            L.polygon(reforestZone, {
                color: '#2D6A4F',
                fillColor: '#D8F3DC',
                fillOpacity: 0.3,
                weight: 2,
                dashArray: '5, 5'
            }).addTo(map).bindPopup("Área de Recuperación Ecológica: Sector Llaullipata");

            evaluarEstadoAdmin();
        });
    </script>

    <!-- Controladores Generales de Modales y Envío de Formulario por WhatsApp -->
    <script>
        window.openModal = function(modalId) {
            const modal = document.getElementById(modalId);
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden'; 
        }

        window.closeModal = function(modalId) {
            const modal = document.getElementById(modalId);
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.style.overflow = 'auto';
            if(modalId === 'admin-login-modal') {
                document.getElementById('login-error').classList.add('hidden');
                document.getElementById('admin-password').value = '';
            }
        }

        // Envío del Formulario
        window.submitForm = function(e) {
            e.preventDefault();
            
            const form = document.getElementById('adoption-form');
            const formData = new FormData(form);

            const nombre = formData.get('nombre');
            const apellidos = formData.get('apellidos');
            const emailAdoptante = formData.get('email');
            const planta = formData.get('planta');

            const nombresPlantas = {
                'queuna': 'La Queuña',
                'chachacomo': 'El Chachacomo',
                'kantuta': 'La Kantuta',
                'mix': 'Paquete Bosque (3 Plantas)'
            };
            const plantaSeleccionada = nombresPlantas[planta] || planta;

            const telefono = "51907261962"; 
            const mensaje = 
                `🌱 *¡Hola Equipo Eco-Ruta!*\n\n` +
                `Quiero adoptar un árbol para Sacsayhuamán. Aquí están mis datos:\n\n` +
                `👤 *Nombre:* ${nombre} ${apellidos}\n` +
                `📧 *Correo:* ${emailAdoptante}\n` +
                `🌳 *Planta elegida:* ${plantaSeleccionada}\n\n` +
                `Por favor, indíquenme los pasos para realizar el aporte y recibir mi código QR.`;
            
            const whatsappUrl = `https://wa.me/${telefono}?text=${encodeURIComponent(mensaje)}`;

            window.open(whatsappUrl, '_blank');

            form.classList.add('hidden');
            document.getElementById('success-message').classList.remove('hidden');
            document.getElementById('success-message').classList.add('flex');
            
            showToast("WhatsApp Abierto", "Tu solicitud fue enviada correctamente. Comunícate por el chat abierto.", "success");
        }

        window.resetForm = function() {
            document.getElementById('adoption-form').reset();
            document.getElementById('success-message').classList.add('hidden');
            document.getElementById('success-message').classList.remove('flex');
            document.getElementById('adoption-form').classList.remove('hidden');
        }

        // Menú móvil toggler
        document.getElementById('mobile-menu-btn').addEventListener('click', () => {
            const menu = document.getElementById('mobile-menu');
            menu.classList.toggle('hidden');
        });
    </script>
